# ============================================================
# MENTE EN FOCO — Plantilla de Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# Stripe (solo la clave PÚBLICA — segura para el browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ⚠️  Las siguientes claves van SOLO en Supabase Edge Function Secrets.
# Nunca las pongas aquí:
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
